# ─── Database (Supabase Postgres) ─────────────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → "Connection string"
# Use the "Transaction" pooler URL (port 6543) for the app, "Session" (5432) for migrations.
DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ─── Supabase Auth ────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...        # "anon public" key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...            # "service_role secret" key (server-only, never expose)

# Configure Google as an auth provider in Supabase Dashboard → Authentication → Providers.
# Set the redirect URL to: http://localhost:3000/auth/callback (dev) and https://<your-domain>/auth/callback (prod).

# ─── Cloudflare R2 (file storage) ─────────────────────────────────────────────
# Cloudflare Dashboard → R2 → Manage R2 API Tokens → Create token (read & write)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=style-iconoclast
# Optional: bind a custom domain to the bucket and set the public URL here to skip signing.
# R2_PUBLIC_URL=https://media.your-domain.com
# Optional: signed URL TTL in seconds (default 3600).
# R2_SIGNED_URL_TTL_SECONDS=3600

# ─── OpenAI (LLM features) ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional model override (default: gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini
# Optional alternative endpoint (e.g., proxy or self-hosted gateway).
# OPENAI_BASE_URL=

# ─── Resend (transactional email / owner notifications) ───────────────────────
RESEND_API_KEY=re_...
NOTIFY_FROM_EMAIL="Style Iconoclast <noreply@your-domain.com>"
NOTIFY_OWNER_EMAIL=you@your-domain.com

# ─── Misc ─────────────────────────────────────────────────────────────────────
# Manus-era variables (still referenced by _core/imageGeneration.ts, _core/map.ts,
# _core/voiceTranscription.ts, _core/dataApi.ts). Leave empty if you don't use those features.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Legacy — no longer used after the Supabase migration but kept for reference.
JWT_SECRET=
